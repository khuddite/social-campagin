<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ brief.campaign_name }} — Campaign Report</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f0f0f; color: #e0e0e0; padding: 40px; max-width: 1200px; margin: 0 auto; }
  h1 { font-size: 28px; margin-bottom: 8px; }
  .meta { color: #888; margin-bottom: 32px; font-size: 14px; }
  .summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-bottom: 40px; }
  .stat { background: #1a1a2e; padding: 20px; border-radius: 10px; text-align: center; }
  .stat .value { font-size: 32px; font-weight: bold; color: #6ddb6d; }
  .stat .label { font-size: 12px; color: #888; text-transform: uppercase; margin-top: 4px; }
  .product { background: #1a1a2e; border-radius: 12px; padding: 24px; margin-bottom: 24px; }
  .product h2 { font-size: 20px; margin-bottom: 16px; }
  .copy-section { margin-bottom: 16px; }
  .copy-section .label { font-size: 11px; color: #888; text-transform: uppercase; margin-bottom: 4px; }
  .copy-section .text { font-size: 14px; line-height: 1.5; }
  .assets { display: flex; gap: 12px; flex-wrap: wrap; margin: 16px 0; }
  .assets img { border-radius: 8px; max-height: 200px; border: 1px solid #333; }
</style>
</head>
<body>

<h1>{{ brief.campaign_name }}</h1>
<p class="meta">Region: {{ brief.target_region }} ({{ brief.target_language }}) · Audience: {{ brief.target_audience }}</p>

<div class="summary">
  <div class="stat">
    <div class="value">{{ brief.products | length }}</div>
    <div class="label">Products</div>
  </div>
  <div class="stat">
    <div class="value">{{ total_assets }}</div>
    <div class="label">Assets Generated</div>
  </div>
</div>

{% for product in brief.products %}
{% set slug = product.slug %}
<div class="product">
  <h2>{{ product.name }}</h2>

  <div class="copy-section">
    <div class="label">Original Copy</div>
    <div class="text"><strong>{{ copy_variants[slug].headline }}</strong> — {{ copy_variants[slug].body }}</div>
  </div>

  {% if localized_copy.get(slug) %}
  <div class="copy-section">
    <div class="label">Localized ({{ localized_copy[slug].language }})</div>
    <div class="text"><strong>{{ localized_copy[slug].headline }}</strong> — {{ localized_copy[slug].body }}</div>
  </div>
  {% endif %}

  <div class="assets">
    {% for ratio_key, img_b64 in thumbnails.get(slug, {}).items() %}
    <div>
      <img src="data:image/png;base64,{{ img_b64 | safe }}" alt="{{ product.name }} {{ ratio_key }}">
      <div style="text-align:center;font-size:11px;color:#888;margin-top:4px;">{{ ratio_key }}</div>
    </div>
    {% endfor %}
  </div>
</div>
{% endfor %}

<p style="text-align:center;color:#555;margin-top:40px;font-size:12px;">Generated by Social Campaign Agent</p>
</body>
</html>
